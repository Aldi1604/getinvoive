generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  createdAt    DateTime  @default(now())
  isPremium    Boolean   @default(false)
  premiumUntil DateTime?
}

model Invoice {
  id         String   @id @default(uuid())
  clientName String
  items      Json
  total      Float
  userId     String
  createdAt  DateTime @default(now())
}
